# ============================================================
# ApplyFlow — Environment Variables
# Copy to .env and fill in your real values
# NEVER commit .env to version control!
# ============================================================

# --- Google Gemini AI ---
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Gemini model to use. Options (June 2026):
#   gemini-3.5-flash     — Best quality, no shutdown date announced
#   gemini-3.1-flash-lite — Most cost-efficient
# DO NOT USE: gemini-2.0-flash (shut down June 1, 2026)
GEMINI_MODEL=gemini-3.5-flash

# --- Gmail (for cold emails) ---
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# --- Telegram Bot (for daily summaries) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Google Sheets (for application tracking) ---
GOOGLE_SHEETS_CREDS_PATH=./data/google_creds.json
GOOGLE_SHEET_NAME=Internship Tracker

# --- Internshala Login ---
INTERNSHALA_EMAIL=your_email@gmail.com
INTERNSHALA_PASSWORD=your_password_here

# --- LinkedIn Login ---
LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password_here

# --- Bot Behavior ---
# Set HEADLESS=false to show browser windows for debugging
HEADLESS=true
# Max applications submitted per run (safety cap)
MAX_APPLICATIONS_PER_RUN=10
# Set to true to simulate without actually applying
DRY_RUN=false
