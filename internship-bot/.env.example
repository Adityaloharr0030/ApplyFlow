# ============================================================
# ApplyFlow — Environment Variables
# Copy to .env and fill in your real values
# NEVER commit .env to version control!
# ============================================================

# --- Database ---
# For local dev, use sqlite. For production/Render, use Neon Postgres URL.
DATABASE_URL=sqlite:///./applyflow.db
# DATABASE_URL=postgresql://user:password@ep-cool-db.us-east-2.aws.neon.tech/neondb

# --- Google Gemini AI (FREE) ---
# Supports comma-separated keys for load balancing & failover
GEMINI_API_KEY=your_gemini_key_here,your_second_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash
TUNED_SCORER_MODEL=tunedModels/applyflow-scorer-v1-XXXXXX
TUNED_COVER_MODEL=tunedModels/applyflow-coverletter-v1-XXXXXX

# --- Gmail (for cold emails) ---
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# --- Telegram Bot (for instant + daily notifications) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Instant Notifications (ntfy.sh) ---
# Pick a long random string. Anyone who guesses it can read your notifications.
# Install the free ntfy app (Android/iOS), subscribe to this topic.
NTFY_TOPIC=your_random_topic_here

# --- WhatsApp Notifications (CallMeBot) ---
# Get API key by messaging the bot: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=your_phone_here
WHATSAPP_API_KEY=your_apikey_here

# --- Google Sheets (for application tracking) ---
GOOGLE_SHEETS_CREDS_PATH=./data/google_creds.json
GOOGLE_SHEET_NAME=Internship Tracker

# --- Internshala Login ---
INTERNSHALA_EMAIL=your_email@gmail.com
INTERNSHALA_PASSWORD=your_password_here

# --- LinkedIn Login ---
LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password_here

# --- Unstop Login ---
UNSTOP_EMAIL=your_email@gmail.com
UNSTOP_PASSWORD=your_password_here

# --- Bot Behavior ---
# Set HEADLESS=false to show browser windows for debugging
HEADLESS=true
# Max applications submitted per run (safety cap)
MAX_APPLICATIONS_PER_RUN=10
# Set to true to simulate without actually applying or sending emails
# Default: true — flip to false once you trust a platform
DRY_RUN=true

# --- Per-Platform Daily Caps ---
# LinkedIn and Indeed are especially strict about bots; keep caps low
LINKEDIN_MAX_APPLIES=10
INDEED_MAX_APPLIES=10
INTERNSHALA_MAX_APPLIES=15
UNSTOP_MAX_APPLIES=15
